   "metadata": {},
   "source": [
    "We include the target variable in the correlation analysis to identify which \n",
    "features have the strongest linear relationship with machine failure."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "ca1ac6a6-c093-469f-ae61-4207be5e8e27",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
