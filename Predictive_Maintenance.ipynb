    "from sklearn.metrics import precision_recall_curve, auc\n",
    "\n",
    "y_proba = rf.predict_proba(X_test_scaled)[:, 1]\n",
    "\n",
    "precision_vals, recall_vals, thresholds = precision_recall_curve(y_test, y_proba)\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.plot(recall_vals, precision_vals, marker='.', color='steelblue')\n",
    "\n",
    "y_pred_default = rf.predict(X_test_scaled)\n",
    "from sklearn.metrics import precision_score, recall_score\n",
    "p_default = precision_score(y_test, y_pred_default)\n",
    "r_default = recall_score(y_test, y_pred_default)\n",
    "plt.scatter(r_default, p_default, color='red', s=100, zorder=5, label=f'Umbral 0.5 (P={p_default:.2f}, R={r_default:.2f})')\n",
    "\n",
    "plt.xlabel('Recall')\n",
    "plt.ylabel('Precision')\n",
