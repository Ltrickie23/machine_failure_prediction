     ]
    }
   ],
   "source": [
    "numeric_columns1 = [\n",
    "    col for col in df1.select_dtypes(include = 'number').columns\n",
    "    if df1[col].nunique() > 2 or col == 'Machine failure'\n",
    "]\n",
    "\n",
    "print(numeric_columns1)"
   ]
  },
